<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  DEBUG / PROFILE — sandbox DISABLED.
	  macOS sandbox blocks access to non-bundled dynamic libraries, preventing dlopen.
	  For production distribution, a statically linked libmpv build
	  is required (all codecs included, no external dependencies).
	-->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!-- Allows loading dylibs not signed by Apple (ad-hoc libmpv) -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<!-- Outbound network access (HTTP/HTTPS audio streaming) -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- File picker: access to user-selected files -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
